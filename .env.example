# Shared environment file for backend and frontend.
# Copy this file to `.env` in the project root and update values as needed.

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Database
# Use sqlite for local development without Docker.
# Use postgres or postgresql when running with PostgreSQL/Docker.
DB_ENGINE=postgres
POSTGRES_DB=product_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

# Frontend
VITE_API_URL=http://localhost:8000/api

# AI Advisor
# Optional. When OPENAI_API_KEY is empty, inventory advice falls back to rule-based analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_CHAT_MODEL=gpt-5.2
